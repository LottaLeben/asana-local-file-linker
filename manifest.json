{
  "manifest_version": 3,
  "name": "Asana Local File Linker",
  "version": "0.1.0",
  "description": "Makes local file paths in Asana tasks clickable. Alt+Click (Option+Click on Mac) opens files with your default app.",
  "key": "",
  "permissions": ["nativeMessaging", "storage"],
  "host_permissions": [
    "https://app.asana.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.asana.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
